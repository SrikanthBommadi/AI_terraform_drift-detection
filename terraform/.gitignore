# Local .terraform directories
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Sensitive variable files
*.tfvars
*.tfvars.json

# CLI config files
.terraformrc
terraform.rc

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform plan output
*.tfplan

# Provider lock file (optional)
# Uncomment if you DON'T want to commit it
# .terraform.lock.hcl

# Editor folders
.vscode/
.idea/

# OS junk
.DS_Store
Thumbs.db